# Copy this file to .env and fill in real values before deploying.
# Never commit the actual .env file -- it's already excluded in .gitignore.

# Secret used to sign JWTs. MUST be a long, random, unguessable value in
# any real deployment. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
AYX_SECRET_KEY=replace-this-with-a-long-random-secret

# Optional: override the default SQLite file path/connection string.
# Leave unset to use the default ./ayx_laundry.db
# DATABASE_URL=sqlite:///./ayx_laundry.db

# Stripe keys are NOT used yet -- all Stripe events are simulated via
# POST /stripe/simulate-event. These are placeholders for when the real
# integration is wired up later.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
